<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:res="clr-namespace:MeteoApp.Resources.Strings"
       x:Class="MeteoApp.MeteoListPage">

    <ContentPage BackgroundColor="#1C1C23">
        <ContentPage.Resources>
            <Color x:Key="CardBackgroundColor">#2C2C36</Color>
            <Color x:Key="PrimaryTextColor">#FFFFFF</Color>
            <Color x:Key="FabBackgroundColor">#E0E0E0</Color>
        </ContentPage.Resources>

        <ContentPage.ToolbarItems>
            <ToolbarItem Text="{x:Static res:AppResources.add}" Clicked="OnItemAdded" />
            <ToolbarItem Text="{x:Static res:AppResources.map}" Clicked="GoToMap" />
        </ContentPage.ToolbarItems>

        <Grid>
            <CollectionView x:Name="zlistView" Margin="20,20,20,0"
                            ItemsSource="{Binding Locations}"
                            SelectionMode="Single"
                            SelectionChanged="OnListItemSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="0,0,0,16">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroupList>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="Selected">
                                            <VisualState.Setters>
                                                <Setter Property="BackgroundColor" Value="Transparent" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateGroupList>
                            </VisualStateManager.VisualStateGroups>
                            <Border StrokeShape="RoundRectangle 16"
                                    BackgroundColor="{StaticResource CardBackgroundColor}"
                                    StrokeThickness="0"
                                    Padding="20">
                                <Grid ColumnDefinitions="Auto, *, Auto">
                                    <Label Grid.Column="1"
                                           Text="{Binding Name}"
                                           TextColor="{StaticResource PrimaryTextColor}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           VerticalOptions="Center" />
                                    <Image Grid.Column="2"
                                           Source="check.png"
                                           HeightRequest="20"
                                           IsVisible="{Binding Done}"
                                           VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </ContentPage>
</Shell>
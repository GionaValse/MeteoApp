<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MeteoApp.Views.SettingsPage"
             xmlns:res="clr-namespace:MeteoApp.Resources.Strings"
             Title="{x:Static res:AppResources.settings_title}">

    <ScrollView Margin="20">
        <VerticalStackLayout Spacing="20">

            <Border Style="{StaticResource WeatherCardStyle}">
                <VerticalStackLayout Spacing="15">

                    <Label Text="{x:Static res:AppResources.general_settings}" FontAttributes="Bold" FontSize="18" />

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray900}}" />

                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Label Text="{x:Static res:AppResources.app_theme}" VerticalOptions="Center" />
                        <Picker x:Name="ThemePicker"
                                Grid.Column="1" 
                                WidthRequest="130"
                                SelectedIndex="{Binding SelectedThemeIndex}" />
                    </Grid>

                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Label Text="{x:Static res:AppResources.app_language}" VerticalOptions="Center" />

                        <Picker Grid.Column="1" 
                                WidthRequest="130"
                                SelectedItem="{Binding Language}">
                            <Picker.Items>
                                <x:String>Italiano</x:String>
                                <x:String>English</x:String>
                                <x:String>Deutsch</x:String>
                            </Picker.Items>
                        </Picker>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray900}}" />

                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Label Text="{x:Static res:AppResources.receive_weather_alerts}" VerticalOptions="Center" />
                        <Switch Grid.Column="1" 
                                IsToggled="{Binding NotificationsEnabled}" 
                                OnColor="{StaticResource Primary}" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource WeatherCardStyle}">
                <VerticalStackLayout Spacing="15">
                    <Label Text="{x:Static res:AppResources.data_sync}" FontAttributes="Bold" FontSize="18" />

                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Label Text="{x:Static res:AppResources.last_update}" VerticalOptions="Center" />

                        <Label Grid.Column="1" 
                               Text="{Binding LastSync, StringFormat='{0:g}'}"
                               TextColor="{StaticResource Gray500}" 
                               VerticalOptions="Center" />
                    </Grid>

                    <Button Text="{x:Static res:AppResources.sync_now}" 
                            Command="{Binding SyncCommand}" 
                            Margin="0,10,0,0" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MeteoApp.Views.SettingsPage"
             Title="Impostazioni">

    <ScrollView Margin="20">
        <VerticalStackLayout Spacing="20">

            <Border Style="{StaticResource WeatherCardStyle}">
                <VerticalStackLayout Spacing="15">

                    <Label Text="Generali" FontAttributes="Bold" FontSize="18" />

                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Label Text="Lingua dell'app" VerticalOptions="Center" />

                        <Picker Grid.Column="1" 
                                WidthRequest="130"
                                SelectedItem="{Binding Language}">
                            <Picker.Items>
                                <x:String>Italiano</x:String>
                                <x:String>English</x:String>
                                <x:String>Français</x:String>
                            </Picker.Items>
                        </Picker>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray900}}" />

                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Label Text="Ricevi avvisi meteo" VerticalOptions="Center" />
                        <Switch Grid.Column="1" 
                                IsToggled="{Binding NotificationsEnabled}" 
                                OnColor="{StaticResource Primary}" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource WeatherCardStyle}">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Sincronizzazione Dati" FontAttributes="Bold" FontSize="18" />

                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Label Text="Ultimo aggiornamento:" VerticalOptions="Center" />

                        <Label Grid.Column="1" 
                               Text="{Binding LastSync, StringFormat='{0:dd/MM/yyyy HH:mm}'}" 
                               TextColor="{StaticResource Gray500}" 
                               VerticalOptions="Center" />
                    </Grid>

                    <Button Text="Sincronizza Ora" 
                            Command="{Binding SyncCommand}" 
                            Margin="0,10,0,0" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
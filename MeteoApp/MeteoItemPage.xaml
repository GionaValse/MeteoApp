<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MeteoApp.MeteoItemPage"
             BackgroundColor="#1C1C23">
    <ScrollView>
        <VerticalStackLayout Padding="30"
                             Spacing="20"
                             VerticalOptions="Center">

            <Label Text="{Binding Location.Name}"
                   FontSize="32"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"/>

            <Image Source="weather_cloud_3d.png"
                   HeightRequest="180"
                   WidthRequest="180"
                   HorizontalOptions="Center">
                <Image.Shadow>
                    <Shadow Brush="Black"
                            Offset="0,10"
                            Opacity="0.4"
                            Radius="15"/>
                </Image.Shadow>
            </Image>

            <Label Text="{Binding Weather.Description}"
                   FontSize="18"
                   TextColor="#A2A2AD"
                   HorizontalOptions="Center"
                   TextTransform="Uppercase"
                   CharacterSpacing="2"/>

            <Label Text="{Binding Weather.Temperature, StringFormat='{0:F0}°'}"
                   FontSize="110"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   Margin="0,-10,0,-10"/>

            <Border StrokeShape="RoundRectangle 20"
                    BackgroundColor="#2C2C36"
                    Padding="20"
                    StrokeThickness="0"
                    HorizontalOptions="Center"
                    WidthRequest="200">
                <VerticalStackLayout Spacing="5"
                                     HorizontalOptions="Center">
                    <Label Text="PERCEPITA"
                           FontSize="12"
                           TextColor="#A2A2AD"
                           HorizontalOptions="Center"
                           FontAttributes="Bold"/>
                    <Label Text="{Binding Weather.FeelsLike, StringFormat='{0:F1} °C'}"
                           FontSize="22"
                           TextColor="White"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
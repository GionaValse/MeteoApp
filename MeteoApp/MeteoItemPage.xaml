<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MeteoApp.MeteoItemPage"
             xmlns:local="clr-namespace:MeteoApp.Components.Pages"
             BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}"
             Title="{Binding Location.Name}">

    <ScrollView>
        <VerticalStackLayout Padding="30"
                             Spacing="20"
                             VerticalOptions="Center">

            <Label Text="{Binding Weather.Description}"
                   FontSize="18"
                   TextColor="{StaticResource Gray500}"
                   HorizontalOptions="Center"
                   TextTransform="Uppercase"
                   CharacterSpacing="2"/>

            <Label Text="{Binding Weather.Temperature, StringFormat='{0:F0}°'}"
                   FontSize="110"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                   HorizontalOptions="Center"
                   Margin="0,-10,0,-10"/>

            <Border StrokeShape="RoundRectangle 20"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                    Padding="20"
                    StrokeThickness="0"
                    HorizontalOptions="Center">

                <HorizontalStackLayout Spacing="5" HorizontalOptions="Center">
                    <Label Text="Max"
                           TextColor="{StaticResource Gray500}"
                           HorizontalOptions="Center"
                           FontAttributes="Bold"/>
                    <Label Text="{Binding Weather.TemperatureMax, StringFormat='{0:F0} °C'}"
                           TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>

                    <Label Text=" | "
                           TextColor="{StaticResource Gray500}"
                           HorizontalOptions="Center"
                           FontAttributes="Bold"/>

                    <Label Text="Min"
                           TextColor="{StaticResource Gray500}"
                           HorizontalOptions="Center"
                           FontAttributes="Bold"/>
                    <Label Text="{Binding Weather.TemperatureMin, StringFormat='{0:F0} °C'}"
                           TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>

            <BlazorWebView HostPage="wwwroot/index.html">
                <BlazorWebView.RootComponents>
                    <RootComponent Selector="#app" ComponentType="{x:Type local:Grafico}" />
                </BlazorWebView.RootComponents>
            </BlazorWebView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
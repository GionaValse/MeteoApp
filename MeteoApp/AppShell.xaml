<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:local="clr-namespace:MeteoApp.Views"
       x:Class="MeteoApp.AppShell"
       xmlns:res="clr-namespace:MeteoApp.Resources.Strings"
       Shell.FlyoutBehavior="Disabled">
    <TabBar>
        <Tab Title="Home" Icon="home.png">
            <ShellContent 
                Title="Home"
                Route="HomePage" 
                ContentTemplate="{DataTemplate local:HomePage}" />
        </Tab>

        <Tab Title="{x:Static res:AppResources.settings_title}" Icon="settings.png">
            <ShellContent 
                Title="{x:Static res:AppResources.settings_title}"
                Route="SettingsPage" 
                ContentTemplate="{DataTemplate local:SettingsPage}" />
        </Tab>
    </TabBar>
</Shell>